generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  role         AdminRole     @default(EDITOR)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  articles     NewsArticle[]

  @@index([email])
}

model ContactMessage {
  id        String               @id @default(cuid())
  fullName  String
  email     String
  subject   String
  message   String
  status    ContactMessageStatus @default(NEW)
  createdAt DateTime             @default(now())
}

model JobOffer {
  id           String           @id @default(cuid())
  title        String
  slug         String           @unique
  department   String
  location     String
  type         JobType
  description  String
  requirements String
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  applications JobApplication[]

  @@index([slug])
}

model JobApplication {
  id         String               @id @default(cuid())
  jobOfferId String?
  fullName   String
  email      String
  phone      String
  message    String
  cvUrl      String
  status     JobApplicationStatus @default(RECEIVED)
  createdAt  DateTime             @default(now())
  jobOffer   JobOffer?            @relation(fields: [jobOfferId], references: [id])
}

model NewsArticle {
  id            String          @id @default(cuid())
  title         String
  slug          String          @unique
  excerpt       String
  content       String
  coverImageUrl String?
  category      ArticleCategory
  isPublished   Boolean         @default(false)
  publishedAt   DateTime?
  authorId      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  author        AdminUser       @relation(fields: [authorId], references: [id])

  @@index([slug])
}

model Partner {
  id         String          @id @default(cuid())
  name       String
  logoUrl    String
  websiteUrl String?
  category   PartnerCategory
  isActive   Boolean         @default(true)
  order      Int             @default(0)
  createdAt  DateTime        @default(now())
}

model MediaItem {
  id        String    @id @default(cuid())
  title     String
  url       String
  type      MediaType
  category  String
  createdAt DateTime  @default(now())
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  isActive       Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@map("newsletter_subscribers")
}

model SiteSettings {
  id           String   @id @default("singleton")
  phone        String   @default("")
  email        String   @default("")
  address      String   @default("")
  city         String   @default("Cotonou, Bénin")
  linkedinUrl  String   @default("")
  facebookUrl  String   @default("")
  instagramUrl String   @default("")
  youtubeUrl   String   @default("")
  updatedAt    DateTime @updatedAt
}

enum AdminRole {
  ADMIN
  EDITOR
}

enum ContactMessageStatus {
  NEW
  READ
  ARCHIVED
}

enum JobType {
  CDI
  CDD
  STAGE
  FREELANCE
}

enum JobApplicationStatus {
  RECEIVED
  REVIEWED
  REJECTED
  ACCEPTED
}

enum ArticleCategory {
  ACTUALITE
  EVENEMENT
  COMMUNIQUE
}

enum PartnerCategory {
  INSTITUTIONNEL
  TECHNIQUE
  COMMERCIAL
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}
